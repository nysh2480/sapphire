{
  "manifest_version": 3,
  "name": "Sapphire Bridge Pro",
  "version": "2.0",
  "description": "CSP-Safe Bridge for Sapphire IDE (file:// + LLM sites) with Memory Bank",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "file:///*",
    "https://claude.ai/*",
    "https://aistudio.google.com/*",
    "https://grok.com/*",
    "https://grok.x.ai/*",
    "https://x.com/grok*",
    "https://x.com/i/grok*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "file:///*",
        "https://claude.ai/*",
        "https://aistudio.google.com/*",
        "https://grok.com/*",
        "https://grok.x.ai/*",
        "https://x.com/grok*",
        "https://x.com/i/grok*"
      ],
      "js": ["content_llm.js"],
      "css": ["bridge.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["file:///*"],
      "js": ["content_sapphire.js"],
      "run_at": "document_idle"
    }
  ]
}
